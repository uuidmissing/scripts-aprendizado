# ========================================
# Arquivo de exemplo de variáveis de ambiente
# ========================================
# Renomeie este arquivo para .env
# Execute: source .env
# para carregar todas as variáveis de ambiente

# ========================================
# Git & GitHub
# ========================================
export NOME="seu_usuario_github"
export TOKEN="seu_token_pessoal_github"
export ENV_ON="true"  # Flag para verificar se variáveis foram carregadas

# ========================================
# OSINT - Ferramentas de Segurança
# ========================================
# Shodan - Motor de busca para dispositivos conectados
export SHODAN_API_KEY=""

# Outras potenciais APIs de segurança
export VIRUSTOTAL_API_KEY=""
export CENSYS_API_KEY=""
export CENSYS_SECRET=""
